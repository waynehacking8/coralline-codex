#!/usr/bin/env bash
set -euo pipefail

resolve_self() {
  local source=${BASH_SOURCE[0]} dir
  while [ -L "$source" ]; do
    dir=$(CDPATH='' cd -P -- "$(dirname -- "$source")" && pwd)
    source=$(readlink -- "$source")
    [[ $source != /* ]] && source=$dir/$source
  done
  CDPATH='' cd -P -- "$(dirname -- "$source")/.." && pwd
}
ROOT=$(resolve_self)
CODEX_DIR=${CODEX_HOME:-$HOME/.codex}
CONFIG=${CORALLINE_CODEX_CONFIG:-$CODEX_DIR/coralline-codex.conf}
CODEX_BIN=${CORALLINE_CODEX_BIN:-$(command -v codex || true)}
CORALLINE_CLEANUP_SOCKET=
CORALLINE_CLEANUP_TEMP=
CORALLINE_CLEANUP_USAGE_PID=

cleanup_companion() {
  if [ -n "$CORALLINE_CLEANUP_USAGE_PID" ]; then
    kill "$CORALLINE_CLEANUP_USAGE_PID" >/dev/null 2>&1 || true
    wait "$CORALLINE_CLEANUP_USAGE_PID" >/dev/null 2>&1 || true
  fi
  if [ -n "$CORALLINE_CLEANUP_SOCKET" ]; then
    TMUX='' tmux -L "$CORALLINE_CLEANUP_SOCKET" kill-server >/dev/null 2>&1 || true
  fi
  if [ -n "$CORALLINE_CLEANUP_TEMP" ] && [ -d "$CORALLINE_CLEANUP_TEMP" ]; then
    rm -rf -- "$CORALLINE_CLEANUP_TEMP"
  fi
}

usage() {
  cat <<'EOF'
usage: coralline-codex [command] [arguments]

Commands:
  run [CODEX_ARGS...]   launch Codex with the native footer and companion bar
  render [ARGS...]      render the companion once
  usage                 refresh and show plan limits and account token activity
  shell ACTION [ARGS]   install, remove, or inspect the optional codex shell hook
  preview               preview every bundled theme
  configure [ARGS...]   update companion configuration safely
  verify                verify the installed integration
  update                update from the GitHub repository
  uninstall             remove the port, retaining recoverable backups

With no command, arguments are passed to an interactive Codex run.
Use --no-companion before Codex arguments to keep only the themed native footer.
EOF
}

native_args() {
  NATIVE_ARGS=()
  local native=on theme=claude-coral fields toml field separator
  # User-selected companion configuration.
  # shellcheck disable=SC1090
  [ -f "$CONFIG" ] && . "$CONFIG"
  native=${CC_NATIVE_STATUS:-on}; theme=${CC_THEME:-claude-coral}
  fields=${CC_NATIVE_FIELDS:-model-with-reasoning context-remaining five-hour-limit weekly-limit used-tokens}
  if [ "$native" = on ]; then
    if [ "$fields" != inherit ]; then
      toml='['; separator=
      for field in $fields; do
        case $field in
          model | model-name | model-with-reasoning | reasoning | current-dir | project-name | project-root | git-branch | pull-request-number | branch-changes | run-state | status | permissions | approval-mode | approval | context-remaining | context-used | context-usage | five-hour-limit | weekly-limit | codex-version | context-window-size | used-tokens | total-input-tokens | total-output-tokens | thread-id | session-id | fast-mode | raw-output | thread-title | workspace-headline | task-progress) ;;
          *)
            printf 'coralline-codex: unsupported native status field: %s\n' "$field" >&2
            return 2 ;;
        esac
        toml+="$separator\"$field\""; separator=,
      done
      toml+=']'
      NATIVE_ARGS+=(-c "tui.status_line=$toml")
    fi
    NATIVE_ARGS+=(
      -c tui.status_line_use_colors=true
      -c "tui.theme=\"coralline-$theme\""
    )
  fi
}

run_codex() {
  [ -n "$CODEX_BIN" ] || { printf 'coralline-codex: codex is not installed or not on PATH\n' >&2; return 127; }
  local companion=1
  if [ "${1:-}" = --no-companion ]; then companion=0; shift; fi
  case ${1:-} in
    exec | e | review | doctor | mcp | mcp-server | plugin | login | logout | completion | update | features | help | apply | sandbox | app-server | exec-server)
      companion=0 ;;
  esac
  native_args
  local -a codex_command=("$CODEX_BIN" "${NATIVE_ARGS[@]}" "$@")
  if ((companion == 0)) || [ ! -t 0 ] || [ ! -t 1 ] || ! command -v tmux >/dev/null 2>&1; then
    exec "${codex_command[@]}"
  fi

  local temp socket session launch row_script start effective bg rate_cache session_cache agent_cache pane_pid usage_refresh agents_enabled agent_rows row
  local -a watcher_agent_args=()
  temp=$(mktemp -d "${TMPDIR:-/tmp}/coralline-codex.XXXXXX")
  socket=coralline-$$
  session=codex
  start=$(date +%s)
  rate_cache=$CODEX_DIR/coralline-codex-cache/rate.env
  session_cache=$temp/session.env
  agent_cache=$temp/agents.env
  CORALLINE_CLEANUP_SOCKET=$socket
  CORALLINE_CLEANUP_TEMP=$temp
  trap cleanup_companion EXIT
  trap 'exit 129' HUP
  trap 'exit 130' INT
  trap 'exit 143' TERM

  effective=$(python3 "$ROOT/lib/config.py" effective --codex-home "$CODEX_DIR" --shell -- "$@")
  {
    printf 'CORALLINE_START_EPOCH=%q\n' "$start"
    printf 'CORALLINE_RATE_CACHE=%q\n' "$rate_cache"
    printf 'CORALLINE_SESSION_CACHE=%q\n' "$session_cache"
    printf 'CORALLINE_AGENT_CACHE=%q\n' "$agent_cache"
    printf '%s\n' "$effective"
  } > "$temp/state"
  launch=$temp/launch.sh
  {
    printf '#!/usr/bin/env bash\nexec'
    printf ' %q' "${codex_command[@]}"
    printf '\n'
  } > "$launch"
  chmod 700 "$launch"
  row_script=$temp/status-row.sh
  {
    # Emits a script whose variables expand when tmux invokes it.
    # shellcheck disable=SC2016
    printf '#!/usr/bin/env bash\nset -u\nrow=${1:-0}\ncount=0\n'
    printf 'agent_cache=%q\nrows_state=%q\n' "$agent_cache" "$temp/status-rows"
    # shellcheck disable=SC2016
    printf 'if [ -f "$agent_cache" ]; then . "$agent_cache"; count=${CORALLINE_AGENT_COUNT:-0}; fi\n'
    # shellcheck disable=SC2016
    printf '[[ $count =~ ^[0-4]$ ]] || count=0\n'
    # shellcheck disable=SC2016
    printf 'if ((row == 0)); then desired=$((count + 1)); current=$(< "$rows_state" 2>/dev/null || printf 0); if [ "$desired" != "$current" ]; then status_value=$desired; ((desired == 1)) && status_value=on; '
    # shellcheck disable=SC2016
    printf 'TMUX= tmux -L %q set-option -g status "$status_value" >/dev/null 2>&1 || true; printf %s "$desired" > "$rows_state"; fi; fi\n' "$socket" '%s'
    # Emits a script that expands width at render time.
    # shellcheck disable=SC2016
    printf 'width=$(env -u TMUX tmux -L %q display-message -p -t %q %q 2>/dev/null || printf 120)\n' \
      "$socket" "$session" '#{client_width}'
    # shellcheck disable=SC2016
    printf 'if ((row < count)); then exec %q --tmux --agent "$((row + 1))" --width "$width" --cwd %q --state %q --config %q; fi\n' \
      "$ROOT/lib/render.sh" "$PWD" "$temp/state" "$CONFIG"
    # shellcheck disable=SC2016
    printf 'exec %q --tmux --width "$width" --cwd %q --state %q --config %q\n' \
      "$ROOT/lib/render.sh" "$PWD" "$temp/state" "$CONFIG"
  } > "$row_script"
  chmod 700 "$row_script"
  bg=$(awk -F '\t' -v wanted="${CC_THEME:-claude-coral}" '$1 == wanted { print $2; exit }' "$ROOT/themes/palettes.tsv")
  bg=${bg:-#1e1f2a}

  TMUX='' tmux -L "$socket" -f /dev/null new-session -d -s "$session" -c "$PWD" "$launch"
  pane_pid=$(TMUX='' tmux -L "$socket" display-message -p -t "$session" '#{pane_pid}' 2>/dev/null || printf 0)
  usage_refresh=${CC_USAGE_REFRESH:-60}
  agents_enabled=${CC_AGENTS:-on}
  agent_rows=${CC_AGENT_ROWS:-3}
  if ! [[ $usage_refresh =~ ^[0-9]+$ ]] || ((usage_refresh < 30)); then usage_refresh=60; fi
  if ! [[ $agent_rows =~ ^[1-4]$ ]]; then agent_rows=3; fi
  if [[ $pane_pid =~ ^[1-9][0-9]*$ ]]; then
    if [ "$agents_enabled" = on ]; then watcher_agent_args=(--agent-cache "$agent_cache" --agent-rows "$agent_rows"); fi
    python3 "$ROOT/lib/usage.py" watch \
      --codex-bin "$CODEX_BIN" --codex-home "$CODEX_DIR" \
      --rate-cache "$rate_cache" --history "$CODEX_DIR/coralline-codex-cache/usage-history.json" \
      --session-cache "$session_cache" \
      --start-epoch "$start" --cwd "$PWD" --pid "$pane_pid" \
      --interval "$usage_refresh" "${watcher_agent_args[@]}" >"$temp/usage.log" 2>&1 &
    CORALLINE_CLEANUP_USAGE_PID=$!
  fi
  printf '1' > "$temp/status-rows"
  TMUX='' tmux -L "$socket" set-option -g status on
  TMUX='' tmux -L "$socket" set-option -g status-position bottom
  TMUX='' tmux -L "$socket" set-option -g status-interval 1
  TMUX='' tmux -L "$socket" set-option -g status-left-length 1000
  TMUX='' tmux -L "$socket" set-option -g status-right-length 0
  TMUX='' tmux -L "$socket" set-option -g status-right ''
  TMUX='' tmux -L "$socket" set-option -g status-style "bg=$bg"
  TMUX='' tmux -L "$socket" set-option -g status-left ''
  for ((row = 0; row <= agent_rows; row++)); do
    TMUX='' tmux -L "$socket" set-option -g "status-format[$row]" "#($row_script $row)"
  done
  TMUX='' tmux -L "$socket" attach-session -t "$session"
}

subcommand=${1:-run}
case $subcommand in
  run) (($#)) && shift; run_codex "$@" ;;
  render) shift; exec "$ROOT/lib/render.sh" "$@" ;;
  usage)
    shift
    exec python3 "$ROOT/lib/usage.py" status --codex-bin "$CODEX_BIN" \
      --rate-cache "$CODEX_DIR/coralline-codex-cache/rate.env" \
      --history "$CODEX_DIR/coralline-codex-cache/usage-history.json" "$@" ;;
  shell)
    shift
    shell_action=${1:-status}
    (($#)) && shift
    shell_common=(--codex-home "$CODEX_DIR" --backup-dir "$CODEX_DIR/coralline-codex-backups/shell")
    if [ "$shell_action" = install ]; then
      wrapper_command=$(command -v coralline-codex 2>/dev/null || printf '%s' "$ROOT/bin/coralline-codex")
      exec python3 "$ROOT/lib/shell_integration.py" install "${shell_common[@]}" \
        --wrapper "$wrapper_command" --codex-bin "$CODEX_BIN" "$@"
    fi
    exec python3 "$ROOT/lib/shell_integration.py" "$shell_action" "${shell_common[@]}" "$@" ;;
  preview)
    shift
    preview_now=$(date +%s)
    while IFS=$'\t' read -r theme _; do
      [[ $theme == \#* || -z $theme ]] && continue
      printf '%-20s ' "$theme"
      CC_THEME=$theme CC_SEGMENTS='limits burn tokens context dir git model reasoning elapsed clock' \
        CORALLINE_RATE_AVAILABLE=1 CORALLINE_LIMIT_COUNT=1 \
        CORALLINE_LIMIT1_LABEL=7d CORALLINE_LIMIT1_USED=15 CORALLINE_LIMIT1_REMAINING=85 \
        CORALLINE_LIMIT1_RESET=$((preview_now + 597600)) CORALLINE_RATE_UPDATED=$preview_now \
        CORALLINE_LIMIT1_BURN_STATE=tracking CORALLINE_LIMIT1_BURN_ETA=302400 \
        CORALLINE_SESSION_AVAILABLE=1 CORALLINE_SESSION_TOTAL=12463 \
        CORALLINE_SESSION_INPUT=12456 CORALLINE_SESSION_OUTPUT=7 \
        CORALLINE_CONTEXT_USED=42000 CORALLINE_CONTEXT_WINDOW=200000 \
        CORALLINE_MODEL=gpt-5.6-codex CORALLINE_REASONING=high CORALLINE_START_EPOCH=$((preview_now - 754)) \
        CORALLINE_CODEX_CONFIG=/dev/null "$ROOT/lib/render.sh" --width 200 "$@"
    done < "$ROOT/themes/palettes.tsv" ;;
  configure) shift; exec "$ROOT/configure.sh" "$@" ;;
  verify) shift; exec "$ROOT/test/verify-install.sh" --codex-home "$CODEX_DIR" "$@" ;;
  update)
    shift
    temp=$(mktemp -d "${TMPDIR:-/tmp}/coralline-update.XXXXXX")
    trap 'rm -rf -- "$temp"' EXIT
    git clone --depth 1 https://github.com/waynehacking8/coralline-codex.git "$temp/repo"
    bash "$temp/repo/install.sh" --update "$@" ;;
  uninstall)
    shift
    case $(uname -s) in
      MINGW* | MSYS* | CYGWIN*)
        uninstall_temp=$(mktemp -d "${TMPDIR:-/tmp}/coralline-uninstall.XXXXXX")
        cp -p -- "$ROOT/install.sh" "$uninstall_temp/install.sh"
        exec bash -c 'temp=$1; shift; trap '\''rm -rf -- "$temp"'\'' EXIT; bash "$temp/install.sh" --uninstall "$@"' \
          _ "$uninstall_temp" "$@" ;;
      *) exec bash "$ROOT/install.sh" --uninstall "$@" ;;
    esac ;;
  -h | --help | help) usage ;;
  *) run_codex "$@" ;;
esac
